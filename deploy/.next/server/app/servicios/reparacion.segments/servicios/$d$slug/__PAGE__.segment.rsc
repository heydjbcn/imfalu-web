2:Ta06,{"@context":"https://schema.org","@graph":[{"@type":"Service","name":"Reparación de fachadas de aluminio y cristal en Barcelona","serviceType":"Reparación y reposición","areaServed":"Barcelona y área metropolitana","provider":{"@type":"HomeAndConstructionBusiness","name":"IMFALÚ","telephone":"+34697158466"},"description":"Reparamos y reponemos los elementos dañados de la fachada de aluminio y cristal: desde un cristal roto en altura hasta juntas, sellados y perfilería de muro cortina. Sustituimos vidrios de cualquier medida y peso con los medios de elevación y la seguridad necesarios, y disponemos de servicio de urgencias 24 h ante cualquier riesgo en la fachada."},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Inicio","item":"https://imfalu.com"},{"@type":"ListItem","position":2,"name":"Servicios","item":"https://imfalu.com/#servicios"},{"@type":"ListItem","position":3,"name":"Reparación y reposición","item":"https://imfalu.com/servicios/reparacion"}]},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"¿Cómo se repara una fachada de vidrio o cristal?","acceptedAnswer":{"@type":"Answer","text":"Según el daño: reposición del vidrio afectado (de cualquier medida y peso), sustitución de juntas y sellados, o reparación de la perfilería de aluminio. Empezamos con un diagnóstico y resolvemos en altura con medios certificados, sin sustituir toda la fachada."}},{"@type":"Question","name":"¿Reponéis cristales rotos de fachada de cualquier tamaño?","acceptedAnswer":{"@type":"Answer","text":"Sí. Reponemos y sustituimos cristales de cualquier medida y peso, con los medios de elevación y seguridad necesarios para trabajo en altura."}},{"@type":"Question","name":"¿Tenéis servicio de urgencias por un cristal roto?","acceptedAnswer":{"@type":"Answer","text":"Sí, disponemos de servicio de urgencias 24 h para cristales rotos, desprendimientos o riesgos en fachada en Barcelona y área metropolitana."}},{"@type":"Question","name":"¿Reparáis elementos de aluminio dañados sin cambiar toda la fachada?","acceptedAnswer":{"@type":"Answer","text":"Sí. Reparamos y reponemos los elementos constructivos dañados puntualmente, sin necesidad de sustituir la fachada completa."}},{"@type":"Question","name":"¿Cuánto cuesta reponer un cristal de fachada?","acceptedAnswer":{"@type":"Answer","text":"Depende del tamaño y peso del vidrio, la altura y la accesibilidad. Tras valorarlo te damos un presupuesto cerrado; en casos urgentes priorizamos la seguridad de inmediato."}}]}]}0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","section",null,{"className":"bg-cream","children":["$","div",null,{"className":"container-x py-12 md:py-16","children":[["$","nav",null,{"className":"mb-5 flex items-center gap-1.5 text-sm text-warm","children":[["$","$L3",null,{"href":"/","className":"hover:text-burdeos","children":"Inicio"}],["$","$L4",null,{"iconNode":[["path",{"d":"m9 18 6-6-6-6","key":"mthhwq"}]],"className":"lucide-chevron-right h-3.5 w-3.5"}],["$","$L3",null,{"href":"/#servicios","className":"hover:text-burdeos","children":"Servicios"}],["$","$L4",null,{"iconNode":"$0:rsc:props:children:0:1:props:children:props:children:0:props:children:1:props:iconNode","className":"lucide-chevron-right h-3.5 w-3.5"}],["$","span",null,{"className":"text-ink","children":"Reparación y reposición"}]]}],["$","h1",null,{"className":"max-w-3xl text-3xl font-bold text-ink md:text-4xl","children":"Reparación de fachadas de aluminio y cristal en Barcelona"}],"$L5"]}]}],"$L6","$L7","$L8"],["$L9"],"$La"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"SlaT5YzTEgVPv2DXRcZ_h"}
