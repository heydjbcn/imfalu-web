22:T99e,{"@context":"https://schema.org","@graph":[{"@type":"Service","name":"Informe técnico y auditoría de fachada en Barcelona","serviceType":"Informes técnicos y auditorías","areaServed":"Barcelona y área metropolitana","provider":{"@type":"HomeAndConstructionBusiness","name":"IMFALÚ","telephone":"+34697158466"},"description":"Antes de intervenir una fachada conviene saber exactamente en qué estado está. Elaboramos informes técnicos y auditorías de fachadas de aluminio y cristal: diagnóstico de patologías, evaluación de riesgos y un plan de actuación priorizado, con la documentación que permite decidir cualquier obra con criterio y sin sorpresas."},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Inicio","item":"https://imfalu.com"},{"@type":"ListItem","position":2,"name":"Servicios","item":"https://imfalu.com/#servicios"},{"@type":"ListItem","position":3,"name":"Informes técnicos y auditorías","item":"https://imfalu.com/servicios/informes-tecnicos"}]},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"¿Qué incluye un informe técnico de fachada?","acceptedAnswer":{"@type":"Answer","text":"Diagnóstico de patologías, evaluación de riesgos y un plan de actuación priorizado, con la documentación técnica que permite decidir cualquier intervención con criterio."}},{"@type":"Question","name":"¿Sirve para la inspección técnica del edificio (ITE/IEE)?","acceptedAnswer":{"@type":"Answer","text":"El informe documenta el estado de la fachada y las actuaciones recomendadas, útil como base técnica para la gestión del edificio. Coordinamos con el técnico responsable cuando es necesario."}},{"@type":"Question","name":"¿Hacéis auditoría antes de presupuestar una obra?","acceptedAnswer":{"@type":"Answer","text":"Sí. Recomendamos el diagnóstico previo para dimensionar bien la intervención y evitar sorpresas durante la obra."}},{"@type":"Question","name":"¿En cuánto tiempo entregáis el informe técnico?","acceptedAnswer":{"@type":"Answer","text":"Tras la inspección, normalmente en pocos días, según la complejidad de la fachada. Te avanzamos los hallazgos urgentes de inmediato."}},{"@type":"Question","name":"¿El informe incluye un plan de actuación con prioridades?","acceptedAnswer":{"@type":"Answer","text":"Sí. No solo diagnosticamos: priorizamos qué actuar primero y proponemos cómo, para que decidas con criterio y por fases si hace falta."}}]}]}19:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$22"}}],["$","section",null,{"className":"bg-cream","children":["$","div",null,{"className":"container-x py-12 md:py-16","children":[["$","nav",null,{"className":"mb-5 flex items-center gap-1.5 text-sm text-warm","children":[["$","$L18",null,{"href":"/","className":"hover:text-burdeos","children":"Inicio"}],["$","$L2",null,{"ref":"$undefined","iconNode":[["path",{"d":"m9 18 6-6-6-6","key":"mthhwq"}]],"className":"lucide-chevron-right h-3.5 w-3.5"}],["$","$L18",null,{"href":"/#servicios","className":"hover:text-burdeos","children":"Servicios"}],["$","$L2",null,{"ref":"$undefined","iconNode":"$19:1:props:children:props:children:0:props:children:1:props:iconNode","className":"lucide-chevron-right h-3.5 w-3.5"}],["$","span",null,{"className":"text-ink","children":"Informes técnicos y auditorías"}]]}],["$","h1",null,{"className":"max-w-3xl text-3xl font-bold text-ink md:text-4xl","children":"Informe técnico y auditoría de fachada en Barcelona"}],["$","p",null,{"className":"mt-4 max-w-2xl text-lg leading-relaxed text-warm","children":"Antes de intervenir una fachada conviene saber exactamente en qué estado está. Elaboramos informes técnicos y auditorías de fachadas de aluminio y cristal: diagnóstico de patologías, evaluación de riesgos y un plan de actuación priorizado, con la documentación que permite decidir cualquier obra con criterio y sin sorpresas."}]]}]}],"$L23","$L24","$L25"]
