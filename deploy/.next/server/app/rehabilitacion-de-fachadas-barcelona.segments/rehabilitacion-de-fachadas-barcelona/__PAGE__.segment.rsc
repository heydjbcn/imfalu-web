2:T715,{"@context":"https://schema.org","@graph":[{"@type":"Service","name":"Rehabilitación de fachadas de aluminio y cristal en Barcelona","areaServed":"Barcelona y área metropolitana","provider":{"@type":"HomeAndConstructionBusiness","name":"IMFALÚ","telephone":"+34697158466"},"description":"Especialistas en rehabilitar fachadas metálicas y acristaladas de edificios en Barcelona y área metropolitana. Más de 30 años de experiencia, +300.000 m² intervenidos y +150 edificios. Recuperamos el estado y las prestaciones de la fachada con trabajo en altura certificado."},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"¿Qué incluye una rehabilitación de fachada?","acceptedAnswer":{"@type":"Answer","text":"Un diagnóstico previo, la regeneración o sustitución de los elementos afectados (aluminio, lacados y vidrios), la reparación de daños y, si procede, pruebas de estanqueidad. Todo con medios de elevación y seguridad para trabajo en altura."}},{"@type":"Question","name":"¿Cuándo hay que rehabilitar la fachada de un edificio?","acceptedAnswer":{"@type":"Answer","text":"Cuando hay deterioro visible del aluminio o los lacados, filtraciones, vidrios en mal estado o riesgo de desprendimientos. Un diagnóstico previo confirma el alcance necesario."}},{"@type":"Question","name":"¿Es mejor rehabilitar o sustituir toda la fachada?","acceptedAnswer":{"@type":"Answer","text":"Si la estructura está en buen estado, rehabilitar suele ser más económico y rápido que sustituir. Lo valoramos con el diagnóstico."}},{"@type":"Question","name":"¿Trabajáis para administradores de fincas y property managers?","acceptedAnswer":{"@type":"Answer","text":"Sí, son la mayoría de nuestros clientes, junto con arquitectos y departamentos de mantenimiento de edificios en Barcelona."}}]}]}0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","section",null,{"className":"relative overflow-hidden bg-ink text-white","c